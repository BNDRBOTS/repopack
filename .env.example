# GitHub Personal Access Token — server-side only, never expose to client
GITHUB_PAT=ghp_your_token_here

# Comma-separated list of allowed frontend origins (no trailing slashes)
# Example: https://yourapp.com,https://www.yourapp.com
# REQUIRED — leaving this unset blocks ALL cross-origin requests
ALLOWED_ORIGINS=https://yourapp.com

# Optional shared secret between your frontend and this proxy
# Set the same value in both Railway and your frontend env
# Prevents unauthorized direct hits to your Railway proxy endpoint
PROXY_SECRET=your_random_secret_here

PORT=3000
